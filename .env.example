# Copy to .env before: docker compose up -d --build

# Public URL visitors use (no trailing slash) — your domain or http://YOUR_SERVER_IP
PUBLIC_URL=http://YOUR_SERVER_IP

# HTTP port on the server (80 = standard web)
HTTP_PORT=80

DB_NAME=mayur_abrasives
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
ADMIN_EMAIL=admin@mayur.com
ADMIN_PASSWORD=change-me-strong-password
